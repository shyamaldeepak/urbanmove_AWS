# ════════════════════════════════════════════════════════════════════
# UrbanMove — Environment Configuration
# Fill in every <...> placeholder with real values from AWS Console
# DO NOT commit this file to git — add .env to your .gitignore!
# ════════════════════════════════════════════════════════════════════

# ── Database (RDS PostgreSQL) ────────────────────────────────────────
# Get from: RDS → urbanmove-db → Connectivity → Endpoint
DB_HOST=<RDS endpoint, e.g. urbanmove-db.xxxxxxxxx.us-east-1.rds.amazonaws.com>
DB_PORT=5432
DB_NAME=urbanmove
DB_USER=admin
DB_PASS=UrbanDB!Secure2025

# ── Cache (ElastiCache Redis) ────────────────────────────────────────
# Get from: ElastiCache → urbanmove-cache → Primary Endpoint
REDIS_HOST=<ElastiCache endpoint, e.g. urbanmove-cache.xxxxxx.0001.use1.cache.amazonaws.com>
REDIS_PORT=6379

# ── Kafka (Amazon MSK) ───────────────────────────────────────────────
# Get from: MSK → urbanmove-kafka → View client information → Bootstrap servers (PLAINTEXT)
KAFKA_BROKERS=<broker1:9092,broker2:9092>

# ── S3 Buckets ───────────────────────────────────────────────────────
# Replace YOURNAME with your actual bucket suffix used in Step 6
S3_RAW_BUCKET=urbanmove-mobility-data-YOURNAME
S3_ANALYTICS_BUCKET=urbanmove-analytics-YOURNAME
AWS_REGION=us-east-1

# ── Cognito (Auth) ───────────────────────────────────────────────────
# Get from: Cognito → urbanmove-users → User pool ID
COGNITO_POOL_ID=<User Pool ID, e.g. us-east-1_XXXXXXXXX>
# Get from: Cognito → urbanmove-users → App clients → urbanmove-app → Client ID
COGNITO_CLIENT_ID=<App Client ID, e.g. 1a2b3c4d5e6f7g8h9i0j>

# ── Alerts (SNS) ─────────────────────────────────────────────────────
# Get from: SNS → Topics → urbanmove-alerts → ARN
SNS_TOPIC_ARN=<SNS Topic ARN, e.g. arn:aws:sns:us-east-1:123456789012:urbanmove-alerts>

# ── Application ───────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
# IMPORTANT: Replace with a real random 64-character string!
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_this_to_random_64_char_string
